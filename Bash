# Backend klasörü ve kodları
mkdir backend
echo "from fastapi import FastAPI
import random

app = FastAPI(title='BeygirAdam API')

@app.get('/analiz/{sehir}')
def get_analiz(sehir: str):
    atlar = ['Gülbatur', 'Şahbatur', 'Bold Pilot', 'Rüzgarın Oğlu']
    return {
        'sehir': sehir.upper(),
        'analizler': [{'at': a, 'skor': random.randint(70, 98)} for a in atlar]
    }" > backend/main.py

